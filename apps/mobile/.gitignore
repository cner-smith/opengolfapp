# Native projects regenerated by `expo prebuild` / EAS Build.
# Apps stay in CNG (Continuous Native Generation) mode — modify
# native config via Expo config plugins, not by hand.
/android
/ios

# Expo
.expo/
.expo-shared/

# Metro / build artifacts
.metro-health-check*
*.tgz

# Mobile uses npm separately from the pnpm workspace; lockfile is
# regenerated on each EAS build (legacy-peer-deps=true) so we don't
# track it.
package-lock.json

# Local env
.env
.env.*
!.env.example
