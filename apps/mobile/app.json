{
  "expo": {
    "name": "OGA",
    "slug": "oga",
    "scheme": "oga",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.opengolf.oga",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "OGA uses your location during a round to track shots and yardages.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "OGA uses your location during a round to track shots and yardages."
      }
    },
    "android": {
      "package": "app.opengolf.oga",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow OGA to use your location to track shots."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f852bb53-02fc-46a1-b509-4b2170cb6d84"
      }
    }
  }
}
