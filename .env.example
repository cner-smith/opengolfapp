# Root .env example. Copy to apps/web/.env.local and apps/mobile/.env.
# Never commit real values.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Edge Function only)
ANTHROPIC_API_KEY=

# Mapbox
MAPBOX_TOKEN=

# Web (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_MAPBOX_TOKEN=

# Mobile (Expo)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
