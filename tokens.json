{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "caddie": {
    "color": {
      "bg":          { "$value": "#F2EEE5", "$type": "color", "$description": "Page background, warm paper" },
      "surface":     { "$value": "#FBF8F1", "$type": "color", "$description": "Cards, raised surfaces" },
      "surface2":    { "$value": "#EBE5D6", "$type": "color", "$description": "Recessed / chip background" },
      "line":        { "$value": "#D9D2BF", "$type": "color", "$description": "Hairline rule between sections" },
      "lineStrong":  { "$value": "#9F9580", "$type": "color" },
      "ink":         { "$value": "#1C211C", "$type": "color", "$description": "Primary text, near-black" },
      "inkDim":      { "$value": "#5C6356", "$type": "color", "$description": "Secondary text" },
      "inkMute":     { "$value": "#8A8B7E", "$type": "color", "$description": "Captions, kickers" },
      "accent":      { "$value": "#1F3D2C", "$type": "color", "$description": "Deep forest — the ONLY saturated color in the palette" },
      "accentInk":   { "$value": "#F2EEE5", "$type": "color" },
      "pos":         { "$value": "#1F3D2C", "$type": "color" },
      "neg":         { "$value": "#A33A2A", "$type": "color", "$description": "Muted brick — never bright red" },
      "warn":        { "$value": "#A66A1F", "$type": "color", "$description": "Burnt amber" },
      "chip":        { "$value": "#EBE5D6", "$type": "color" },
      "chipOn":      { "$value": "#1F3D2C", "$type": "color" }
    },
    "font": {
      "serif": { "$value": "\"Fraunces\", \"GT Sectra\", Georgia, ui-serif, serif", "$type": "fontFamily" },
      "sans":  { "$value": "\"Inter\", -apple-system, system-ui, sans-serif",       "$type": "fontFamily" },
      "mono":  { "$value": "\"JetBrains Mono\", \"SF Mono\", ui-monospace, monospace", "$type": "fontFamily" }
    },
    "fontSize": {
      "display": { "$value": "38px", "$type": "dimension", "$description": "Serif italic mastheads" },
      "h1":      { "$value": "28px", "$type": "dimension" },
      "h2":      { "$value": "22px", "$type": "dimension" },
      "lede":    { "$value": "17px", "$type": "dimension", "$description": "Serif body lede" },
      "body":    { "$value": "15px", "$type": "dimension" },
      "meta":    { "$value": "13px", "$type": "dimension" },
      "kicker":  { "$value": "10px", "$type": "dimension", "$description": "Mono, uppercase, +0.14em tracking" }
    },
    "letterSpacing": {
      "display": { "$value": "-0.025em", "$type": "dimension" },
      "tight":   { "$value": "-0.015em", "$type": "dimension" },
      "kicker":  { "$value": "0.14em",   "$type": "dimension" },
      "button":  { "$value": "0.02em",   "$type": "dimension" }
    },
    "radius": {
      "default": { "$value": "4px", "$type": "dimension", "$description": "Minimal — this is paper, not plastic" },
      "small":   { "$value": "2px", "$type": "dimension" }
    },
    "space": {
      "1": { "$value": "4px",  "$type": "dimension" },
      "2": { "$value": "8px",  "$type": "dimension" },
      "3": { "$value": "12px", "$type": "dimension" },
      "4": { "$value": "14px", "$type": "dimension" },
      "5": { "$value": "18px", "$type": "dimension" },
      "6": { "$value": "22px", "$type": "dimension" },
      "7": { "$value": "28px", "$type": "dimension" }
    }
  }
}
