# Hoist dependencies into a flat node_modules layout. Required for the React
# Native Gradle plugin, which uses node --print "require.resolve(...)" to
# locate native build inputs. With pnpm's default symlinked layout, transitive
# deps like @react-native/gradle-plugin are not visible from apps/mobile/, so
# Android builds fail with "Included build '.../android/null' does not exist".
node-linker=hoisted
